<UserControl x:Class="AxialSqlTools.SettingsWindowControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	mc:Ignorable="d"
	Name="MyToolWindow">
    
    <DockPanel>
        <Border DockPanel.Dock="Top"
				Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
				Padding="12" BorderBrush="Black" BorderThickness="0,0,0,1">
            <TextBlock Text="Axial SQL Tools - Settings"
					   FontWeight="Bold"
					   FontSize="20"
					   HorizontalAlignment="Center"/>
        </Border>

        <TabControl Margin="5"
					BorderBrush="LightGray"
					BorderThickness="1">

            <TabItem Header="Query Templates">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" HorizontalAlignment="left" >
					  <Run Text="Feature description in"/>
						<Hyperlink
							NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/wiki/Query-Templates-and-Snippets"
							RequestNavigate="buttonWikiPage_Click">
						<Run Text="Wiki"/>
					  </Hyperlink>
                    </TextBlock>

                    <Label Grid.Row="1" Grid.Column="0"
						   Content="Templates Folder:"
						   VerticalAlignment="Center"
						   Margin="5"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
							 x:Name="ScriptFolder"
							 VerticalContentAlignment="Center"
							 Margin="5"/>
                    <Button Grid.Row="2" Grid.Column="1"
							Content="Select folder..."
							Click="BrowseButton_Click"
							Margin="5" Width="120" HorizontalAlignment="Left"
							FontWeight="Bold"/>                   


                    <Button Grid.Row="3" Grid.Column="0"
							x:Name="button_SaveScriptFolder"							
							Click="Button_SaveScriptFolder_Click"
							Width="80" 
							Height="24"
							Margin="5"
							FontWeight="Bold"
                            HorizontalAlignment="Left">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<Image
								Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
								Width="16"
								Height="16"
								Margin="0,0,4,0"/>
								<TextBlock Text="Save" VerticalAlignment="Center"/>
							</StackPanel>
                    </Button>

                                     


                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="5" HorizontalAlignment="left" >
						<Run Text="Useful TSQL scripts"/>
							<Hyperlink
								NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/tree/main/query-library"
								RequestNavigate="buttonWikiPage_Click">
							<Run Text="https://github.com/Axial-SQL/AxialSqlTools/tree/main/query-library"/>
					  </Hyperlink>
                    </TextBlock>
                    
                    <Button Grid.Row="5" Grid.Column="2"
							Content="Download TSQL scripts from GitHub"
							Click="buttonDownloadAxialScripts_Click"
							Margin="5" HorizontalAlignment="Left"
							FontWeight="Bold"/>  
                    
                </Grid>
            </TabItem>

            <TabItem Header="Code Snippets" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" HorizontalAlignment="left" >
					  <Run Text="Feature description in"/>
					  <Hyperlink
							NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/wiki/Query-Templates-and-Snippets"
							RequestNavigate="buttonWikiPage_Click">
						<Run Text="Wiki"/>
					  </Hyperlink>
                    </TextBlock>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
							  x:Name="UseSnippets"
							  Content="Use code snippets (SSMS restart required)"
							  Margin="5"/>

                    <Label Grid.Row="2" Grid.Column="0"
						   Content="Snippets Location:"
						   VerticalAlignment="Center"
						   Margin="5"/>
                    
                    <TextBox Grid.Row="2" Grid.Column="1"
							 x:Name="SnippetFolder"
							 Margin="5" VerticalContentAlignment="Center"/>
                    
                    <Button Grid.Row="3" Grid.Column="1"
							Content="Select folder..."
							Click="SnippetsBrowseButton_Click"
							Margin="5" Width="120" HorizontalAlignment="Left"
							FontWeight="Bold"/>

                    <Label Grid.Row="4" Grid.Column="0"
                                                   Content="Replace snippets when pressing:"
                                                   VerticalAlignment="Center"
                                                   Margin="5"/>

                    <ComboBox Grid.Row="4" Grid.Column="1"
                                                         x:Name="SnippetReplaceMode"
                                                         SelectedValuePath="Tag"
                                                         Margin="5"
                                                         VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Enter" Tag="Enter" />
                        <ComboBoxItem Content="Shift+Enter" Tag="ShiftEnter" />
                    </ComboBox>

                    <Button Grid.Row="5" Grid.Column="0"
                                                        x:Name="button_SaveSnippetFolder"
                                                        Click="Button_SaveSnippetFolder_Click"
                                                        Width="80"
                                                        Height="24"
							Margin="5"
							FontWeight="Bold" 
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image
							Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
							Width="16"
							Height="16"
							Margin="0,0,4,0"/>
							<TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>

            <TabItem Header="Query History">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <!-- new rows for creation script and spacing -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="10" HorizontalAlignment="left">
            <Run Text="Feature description in"/>
            <Hyperlink
                NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/wiki/Query-History"
                RequestNavigate="buttonWikiPage_Click">
                <Run Text="Wiki"/>
            </Hyperlink>
                    </TextBlock>

                    <Label Grid.Row="1" Grid.Column="0"
               Content="Connection Info:"
               Margin="5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                   x:Name="Label_QueryHistoryConnectionInfo"
                   Text="&lt; not configured &gt;"
                   VerticalAlignment="Center"
                   Margin="5"/>

                    <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                Content="Use connection from Object Explorer"
                x:Name="button_SelectDatabaseFromObjectExplorer"
                Click="Button_SelectDatabaseFromObjectExplorer_Click"
                HorizontalAlignment="Left"
                Width="240"
                Margin="5,0,0,5"
                FontWeight="Bold"/>

                    <Label Grid.Row="5" Grid.Column="0"
               Content="Target Table Name:"
               Margin="5"/>
                    <TextBox Grid.Row="5" Grid.Column="1"
                 x:Name="QueryHistoryTableName"
                 ToolTip="Leave blank to use the default [dbo].[QueryHistory] table."
                 VerticalContentAlignment="Center"
                 Margin="5"
                 TextChanged="QueryHistoryTableName_TextChanged"/>

                    <Label Grid.Row="6" Grid.Column="1"
               Content="Leave blank to use the default [dbo].[QueryHistory] table."
               Margin="0,0,0,5"/>

                    <!-- New: creation script viewer -->
                    <GroupBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                  Header="Creation script (for information only)"
                  Margin="5">
                        <Grid>
                            <TextBox x:Name="QueryHistoryCreateScript"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         MinHeight="160"
                         Margin="5"/>
                        </Grid>
                    </GroupBox>

                    <Button Content="Disable Query History"
                Grid.Row="9" Grid.Column="1"
                x:Name="button_DisableQueryHistory"
                Click="Button_DisableQueryHistory_Click"
                Width="150" HorizontalAlignment="Left"
                Margin="5"
                FontWeight="Bold"/>

                    <Button Grid.Row="10" Grid.Column="0"
                x:Name="button_SaveQueryHistory"
                Click="Button_SaveQueryHistory_Click"
                Width="80"
                Height="24"
                Margin="5"
                FontWeight="Bold" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image
                    Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
                    Width="16"
                    Height="16"
                    Margin="0,0,4,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </TabItem>


            <TabItem Header="Code Format">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Margin="5" HorizontalAlignment="left" >
                        <Run Text="Feature description in"/>
                        <Hyperlink
                            NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/wiki/TSQL-Code-Formatting-with-Microsoft-ScriptDOM-library"
                            RequestNavigate="buttonWikiPage_Click">
                            <Run Text="Wiki"/>
                        </Hyperlink>
                    </TextBlock>

                    <!-- all checkboxes in a 3-column UniformGrid -->
                    <UniformGrid Grid.Row="1"
                             Columns="3"
                             Margin="5"
                             HorizontalAlignment="Left">
                        <CheckBox x:Name="PreserveComments" Margin="5"
                              Content="Preserve comments" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="RemoveNewLineAfterJoin" Margin="5"
                              Content="Remove new line after JOIN" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="AddTabAfterJoinOn" Margin="5"
                              Content="Add tab after JOIN..ON" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="MoveCrossJoinToNewLine" Margin="5"
                              Content="Place CROSS/OUTER JOIN/APPLY on a new line" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="FormatCaseAsMultiline" Margin="5"
                              Content="Format CASE expression as multiline" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="AddNewLineBetweenStatementsInBlocks" Margin="5"
                              Content="Add new line between statements in code blocks" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="BreakSprocParametersPerLine" Margin="5"
                              Content="Break exec sproc parameters per line" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="UppercaseBuiltInFunctions" Margin="5"
                              Content="Always upper-case built-in functions" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="UnindentBeginEndBlocks" Margin="5"
                              Content="Unindent Begin..End blocks" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="BreakVariableDefinitionsPerLine" Margin="5"
                              Content="Break variable definitions per line" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <CheckBox x:Name="BreakSprocDefinitionParametersPerLine" Margin="5"
                              Content="Break sproc definition parameters per line" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>
                        <!-- TODO -->
                        <CheckBox x:Name="BreakSelectFieldsAfterTopAndUnindent" Margin="5" Visibility="Hidden"
                              Content="Break SELECT fields after TOP and unindent" 
                              Checked="formatSetting_Checked"
                              Unchecked="formatSetting_Unchecked"/>

                    </UniformGrid>

                    <Button
                        Grid.Row="9"
                        x:Name="button_SaveApplyAdditionalFormat"
                        Click="Button_SaveApplyAdditionalFormat_Click"
                        Width="80" 
                        Height="24"
                        Margin="5"
                        HorizontalAlignment="Left"
                        FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image
                                Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
                                Width="16"
                                Height="16"
                                Margin="0,0,4,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Grid Grid.Row="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Source query" Grid.Column="0">
                            <TextBox x:Name="SourceQueryPreview"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="12"/>
                        </GroupBox>

                        <GroupBox Header="Formatted query" Grid.Column="1">
                            <TextBox x:Name="FormattedQueryPreview"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 IsReadOnly="True"/>
                        </GroupBox>
                    </Grid>

                </Grid>
            </TabItem>


            <TabItem Header="Excel Export">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
							   Margin="5" HorizontalAlignment="left" >
						<Run Text="Feature description in"/>
						<Hyperlink
							NavigateUri="https://github.com/Axial-SQL/AxialSqlTools/wiki/Export-Grid-To-Excel"
							RequestNavigate="buttonWikiPage_Click">
							<Run Text="Wiki"/>
						</Hyperlink>
                    </TextBlock>

                    <CheckBox
						Grid.Row="1" Grid.ColumnSpan="2"
						x:Name="ExcelExportIncludeSourceQuery"
						Content="Include content of attached query-window on its own sheet (hold Shift to do the opposite)"
						Margin="5"/>
                    
                    <CheckBox
						Grid.Row="2" Grid.ColumnSpan="2"
						x:Name="ExcelExportAddAutoFilter"
						Content="Add filter dropdowns to header row (AutoFilter)"
						Margin="5"/>

                    <CheckBox
						Grid.Row="3" Grid.ColumnSpan="2"
						x:Name="ExcelExportBoolsAsNumbers"
						Content="Export booleans as numbers (TRUE/FALSE -> 1/0)"
						Margin="5"/>

                    <Label Grid.Row="4" Grid.Column="0"
						Content="Default Directory:"
						Margin="5"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
						x:Name="ExcelExportDefaultDirectory"
						ToolTip="Leave blank to use the Desktop"
						VerticalContentAlignment="Center"
						Margin="5"/>

                    <Label Grid.Row="5" Grid.Column="1"					
						Content="Leave blank → Desktop" Margin="0,0,0,5"/>

                    <Label Grid.Row="6" Grid.Column="0"
						Content="Default Filename:"
						Margin="5"/>
                    <TextBox Grid.Row="6" Grid.Column="1"
						x:Name="ExcelExportDefaultFilename"
						ToolTip="Leave blank to use DataExport_{yyyyMMdd_HHmmss}.xlsx; date-wildcards supported"
						VerticalContentAlignment="Center"
						Margin="5"/>

                    <Label Grid.Row="7" Grid.Column="1"					
						Content="Leave blank → DataExport__{yyyyMMdd__HHmmss}.xlsx; use {...} for date-wildcards" Margin="0,0,0,0"/>


                    <Button
						Grid.Row="9"
						x:Name="button_SaveExcelExportSettings" 
						Click="button_SaveExcelExportSettings_Click"
						Width="80" 
						Height="24"
						Margin="5"
						HorizontalAlignment="Left"
						FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image
								Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
								Width="16"
								Height="16"
								Margin="0,0,4,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>

            <TabItem Header="Google Sheets">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="5">
                        <Run Text="Authorize AxialSqlTools to create Google Sheets using an OAuth client ID from "/>
                        <Hyperlink NavigateUri="https://console.cloud.google.com/apis/credentials" RequestNavigate="buttonWikiPage_Click">
                            <Run Text="Google Cloud Console" />
                        </Hyperlink>
                        <Run Text="." />
                    </TextBlock>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="GoogleSheetsIncludeSourceQuery" Content="Include content of attached query-window on its own sheet (hold Shift to do the opposite)" Margin="5"/>
                    <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="GoogleSheetsExportBoolsAsNumbers" Content="Export booleans as numbers (TRUE/FALSE -> 1/0)" Margin="5"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Default Spreadsheet Title:" Margin="5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="GoogleSheetsDefaultSpreadsheetName" ToolTip="Leave blank to use DataExport_{yyyyMMdd_HHmmss}" VerticalContentAlignment="Center" Margin="5"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="Client ID:" Margin="5"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="GoogleSheetsClientId" Margin="5"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="Client Secret:" Margin="5"/>
                    <PasswordBox Grid.Row="5" Grid.Column="1" x:Name="GoogleSheetsClientSecret" Margin="5"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="Authorization Status:" Margin="5"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GoogleSheetsRefreshTokenLabel" Margin="5" />

                    <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5">
                        <Button x:Name="button_AuthorizeGoogleSheets" Click="button_AuthorizeGoogleSheets_Click" Width="160" Height="24" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="pack://application:,,,/AxialSqlTools;component/Resources/upload.png" Width="16" Height="16" Margin="0,0,4,0"/>
                                <TextBlock Text="Authorize Google Sheets" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="button_SaveGoogleSheetsSettings" Click="button_SaveGoogleSheetsSettings_Click" Width="80" Height="24">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png" Width="16" Height="16" Margin="0,0,4,0"/>
                                <TextBlock Text="Save" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Connection Colors">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap"
                                   Text="Color the status bar of query windows based on the server and/or database name. If both fields are filled, both must match. Leave a field empty to match anything."/>
                        <TextBlock Margin="0,5,0,0" TextWrapping="Wrap" Foreground="Gray" FontStyle="Italic"
                                   Text="Examples: Server='PROD' matches SQL-PROD-01. Database='master' matches any connection to master. Server='PROD' + Database='Sales' matches only Sales on PROD servers. First matching rule wins."/>
                    </StackPanel>

                    <!-- Add new rule area -->
                    <GroupBox Grid.Row="1" Header="Add new rule" Margin="0,0,0,10" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server name contains:"
                                       VerticalAlignment="Center" Margin="0,0,8,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="NewRuleServerPattern"
                                     VerticalContentAlignment="Center" Padding="4,2" Margin="0,0,0,4"
                                     ToolTip="e.g. PROD, DEV, localhost, 192.168.1 (leave empty to match any server)"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Database name contains:"
                                       VerticalAlignment="Center" Margin="0,0,8,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="NewRuleDatabasePattern"
                                     VerticalContentAlignment="Center" Padding="4,2" Margin="0,0,0,4"
                                     ToolTip="e.g. master, MyDB, _prod (leave empty to match any database)"/>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                        Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Status bar color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border x:Name="NewRuleColorPreview" Width="30" Height="22"
                                        Background="#FF4444" BorderBrush="Gray" BorderThickness="1"
                                        CornerRadius="2" Margin="0,0,5,0"
                                        Cursor="Hand" MouseLeftButtonUp="NewRuleColorPreview_Click"
                                        ToolTip="Click to pick a color"/>
                                <Button Content="Pick color..." Click="NewRuleColorPreview_Click" Margin="0,0,15,0"/>
                                <Button Content="+ Add" Click="ButtonAddColorRule_Click" FontWeight="Bold" Width="60"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Rules list -->
                    <GroupBox Grid.Row="2" Header="Configured rules" Padding="5">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,5,0,0">
                                <Button Content="Edit selected" Click="ButtonEditColorRule_Click"
                                        Width="100" Margin="0,0,5,0" FontWeight="Bold"/>
                                <Button Content="Remove selected" Click="ButtonRemoveColorRule_Click"
                                        Width="120" Margin="0,0,5,0"/>
                            </StackPanel>
                            <ListView x:Name="ConnectionColorRulesListView"
                                      SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Server contains" Width="180"
                                                        DisplayMemberBinding="{Binding ServerNamePattern}"/>
                                        <GridViewColumn Header="Database contains" Width="180"
                                                        DisplayMemberBinding="{Binding DatabaseNamePattern}"/>
                                        <GridViewColumn Header="Color" Width="70">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Width="50" Height="18" CornerRadius="2"
                                                            Background="{Binding StatusBarColor}"
                                                            BorderBrush="Gray" BorderThickness="1"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="RuleColorPreview_Click"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </GroupBox>

                    <Button Grid.Row="3"
                            x:Name="button_SaveConnectionColorRules"
                            Click="Button_SaveConnectionColorRules_Click"
                            Width="80"
                            Height="24"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image
                                Source="pack://application:,,,/AxialSqlTools;component/Resources/save.png"
                                Width="16"
                                Height="16"
                                Margin="0,0,4,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>

            <TabItem Header="SMTP Settings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>

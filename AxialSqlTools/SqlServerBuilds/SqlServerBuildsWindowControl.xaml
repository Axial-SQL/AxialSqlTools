<UserControl x:Class="AxialSqlTools.SqlServerBuildsWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:axialsqltools="clr-namespace:AxialSqlTools"
             Background="{DynamicResource AxialThemeBackgroundBrush}"
             Foreground="{DynamicResource AxialThemeForegroundBrush}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="SQLServerBuilds">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/AxialSqlTools;component/Themes/SharedToolWindowTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AxialThemeBackgroundBrush}">
        <DockPanel HorizontalAlignment="Left">
            <TextBlock Margin="0"  FontWeight="Bold">
                <Run Text="Data Source:" />
                <Hyperlink Click="HyperlinkDataSource_Click">
                    <Run Text="https://aka.ms/sqlserverbuilds" />
                </Hyperlink>
                <Run Text=" | " />
                <Hyperlink Click="HyperlinkCopyAsTSQL_Click">
                    <Run Text="Copy as TSQL" />
                </Hyperlink>
            </TextBlock>
        </DockPanel>
        <TreeView x:Name="sqlVersionTreeView" Margin="0,20,0,0"
                  Background="{DynamicResource AxialThemeBackgroundBrush}"
                  Foreground="{DynamicResource AxialThemeForegroundBrush}"
                  BorderBrush="{DynamicResource AxialThemeBorderBrush}">
            <TreeView.Resources>
                <!-- Style for Grid-like Row -->
                <Style TargetType="TreeViewItem">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="{DynamicResource AxialThemeBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AxialThemeForegroundBrush}"/>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>

<UserControl x:Class="AxialSqlTools.SnippetManagerWindowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AxialSqlTools"
    xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
    Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
    Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
    mc:Ignorable="d"
    Name="SnippetManagerControl">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Theme-aware styles for dark mode support -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="RowBackground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings Section -->
        <GroupBox Grid.Row="0" Header="Settings" Margin="0,0,0,5">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          x:Name="chkUseSnippets"
                          Content="Enable Snippets"
                          IsChecked="{Binding UseSnippets, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="0,0,15,0"/>

                <TextBlock Grid.Column="1" Text="Trigger Key:"
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Grid.Column="2"
                          x:Name="cmbReplaceKey"
                          SelectedValuePath="Tag"
                          Width="100"
                          VerticalAlignment="Center"
                          Margin="0,0,15,0"
                          SelectionChanged="cmbReplaceKey_SelectionChanged">
                    <ComboBoxItem Content="Tab" Tag="Tab"/>
                    <ComboBoxItem Content="Enter" Tag="Enter"/>
                    <ComboBoxItem Content="Shift+Enter" Tag="ShiftEnter"/>
                </ComboBox>

                <TextBlock Grid.Column="3" Text="Cursor Marker:"
                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Grid.Column="4"
                         x:Name="txtCursorMarker"
                         Text="{Binding CursorMarker, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="30"
                         VerticalContentAlignment="Center"
                         Margin="0,0,15,0"/>

                <Button Grid.Column="5"
                        Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        Width="90" Height="24"
                        FontWeight="Bold"/>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <Button Content="+ New" Command="{Binding NewCommand}"
                    Width="70" Height="24" Margin="0,0,5,0" FontWeight="Bold"/>
            <Button Content="Duplicate" Command="{Binding DuplicateCommand}"
                    Width="75" Height="24" Margin="0,0,5,0"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    Width="65" Height="24" Margin="0,0,5,0"/>
            <Button Content="Import .sql" Command="{Binding ImportLegacyCommand}"
                    Width="80" Height="24" Margin="0,0,5,0"/>
        </StackPanel>

        <!-- Main content: Grid on top, Edit panel on bottom -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="100"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Snippets}"
                      SelectedItem="{Binding SelectedSnippet, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Margin="0,0,0,5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Prefix" Binding="{Binding Prefix}" Width="100"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="200"/>
                    <DataGridTextColumn Header="Body (preview)" Binding="{Binding Body}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Edit Panel -->
            <GroupBox Grid.Row="1" Header="Edit Snippet"
                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                      Margin="0,0,0,0">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Prefix:"
                               VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding EditPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:"
                               VerticalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding EditDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Body:"
                               VerticalAlignment="Top" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                             Text="{Binding EditBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             MinHeight="100"
                             Margin="0,0,0,5"/>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Save Snippet" Command="{Binding SaveCommand}"
                                Width="100" Height="24" Margin="0,0,5,0" FontWeight="Bold"/>
                        <Button Content="Cancel" Command="{Binding CancelCommand}"
                                Width="70" Height="24"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
